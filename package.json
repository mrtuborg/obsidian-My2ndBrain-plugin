{
	"name": "obsidian-2ndbrain-plugin",
	"version": "0.1.0",
	"description": "Automates Daily Notes, Activities, and People views in a structured Obsidian vault.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "jest"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^29.5.12",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jest": "^29.7.0",
		"ts-jest": "^29.2.5",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	},
	"dependencies": {
		"obsidian": "latest"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"extensionsToTreatAsEsm": [],
		"moduleNameMapper": {
			"^obsidian$": "<rootDir>/tests/__mocks__/obsidian.ts"
		},
		"testMatch": [
			"**/tests/**/*.test.ts"
		],
		"transform": {
			"^.+\\.tsx?$": ["ts-jest", {
				"useESM": false,
				"tsconfig": {
					"module": "commonjs",
					"esModuleInterop": true
				}
			}]
		}
	}
}
